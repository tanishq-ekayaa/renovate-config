{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges", 
    ":dependencyDashboard"
  ],
  "timezone": "Asia/Kolkata",
  "schedule": ["after 9pm on saturday", "before 6am on sunday"],
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Label all minor updates clearly",
      "matchUpdateTypes": ["minor"],
      "labels": ["minor-bump"]
    },
    {
      "description": "Label all major breaking updates clearly",
      "matchUpdateTypes": ["major"],
      "labels": ["major-bump"]
    },
    {
      "description": "Hold core frameworks 7 days for ecosystem stabilization",
      "matchPackageNames": ["next", "react", "react-dom", "@prisma/client", "prisma"],
      "minimumReleaseAge": "7 days"
    }
  ]
}
